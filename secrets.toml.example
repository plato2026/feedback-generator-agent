# Streamlit Secrets Template
# ===========================
# Copy this file to secrets.toml and add your API key
# 
# Command:
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#
# Then edit secrets.toml and paste your Anthropic API key below.
#
# Get your API key from: https://console.anthropic.com/settings/keys
# 
# IMPORTANT: Never commit secrets.toml to GitHub!
# (It's already listed in .gitignore)

ANTHROPIC_API_KEY = "sk-ant-api03-YOUR-KEY-HERE"
